// ΓΛΩΣΣΑ PEG Grammar
// The living specification for the GLOSSA language
//
// Key design principles:
// 1. Word order is flexible (SOV, VSO, OVS all valid) - morphology determines roles
// 2. Case endings encode semantic roles, not position
// 3. Greek punctuation (Strict Spartan):
//    . (τελεία) - full stop, ends statements
//    · (U+00B7 άνω τελεία / middle dot) - semicolon/colon, chains expressions
//    ; (U+037E ερωτηματικό) - question mark
//    , (comma) - clause separator in control flow
//
// Control flow keywords (εἰ, ἕως, κατά, etc.) are identified in semantic analysis
// using normalized forms, NOT in the grammar. This keeps the grammar simple.

// =============================================================================
// Top-level rules
// =============================================================================

program = { SOI ~ statement* ~ EOI }

statement = { (type_definition | clause_list) ~ statement_end }

statement_end = { period | query }

// Type definition: εἶδος typename ὁρίζειν { fields }
type_definition = { greek_word ~ greek_word ~ greek_word ~ "{" ~ field_list? ~ "}" }

// Field list: field declarations separated by middle dot (·) or period (.)
field_list = { field_declaration ~ ((chain | period) ~ field_declaration)* ~ (chain | period)? }

// Field declaration: fieldname typename_genitive
field_declaration = { greek_word ~ greek_word }

// Clause list: clauses separated by commas (for control flow)
// e.g., "εἰ condition, body" or "ἕως condition, body"
clause_list = { clause ~ (comma ~ clause)* }

// A clause is an expression list (chained with middle dot)
clause = { expression ~ (chain ~ expression)* }

// =============================================================================
// Expressions
// =============================================================================

expression = { term+ }

term = {
    block
    | array_literal
    | string_literal
    | number_literal
    | boolean_literal
    | indexed_word
    | parenthesized_expr
    | greek_word
}

// Parenthesized expression for grouping (e.g., nested function calls)
parenthesized_expr = { "(" ~ expression ~ ")" }

// Indexed word: word[index]
indexed_word = { greek_word ~ "[" ~ index_expr ~ "]" }
index_expr = { number_literal | greek_word }

// Array literal: [element, element, ...]
array_literal = { "[" ~ array_elements? ~ "]" }
array_elements = { array_element ~ ("," ~ array_element)* }
array_element = { string_literal | number_literal | boolean_literal | greek_word }

// A block is a sequence of statements in braces
// Used for multi-statement bodies in control flow
block = { "{" ~ statement* ~ "}" }

// =============================================================================
// Literals
// =============================================================================

// Greek guillemets for strings: «text»
string_literal = { "«" ~ string_content ~ "»" }
string_content = { (!"»" ~ ANY)* }

// Numbers (Arabic numerals for now, Greek numerals later)
number_literal = @{ ASCII_DIGIT+ }

// Boolean literals
boolean_literal = { "ἀληθές" | "ψεῦδος" | "αληθες" | "ψευδος" }

// =============================================================================
// Greek words
// =============================================================================

// A Greek word is a sequence of Greek letters (with optional diacritics)
greek_word = @{ GREEK_CHAR+ }

// Greek characters including polytonic diacritics
GREEK_CHAR = {
    GREEK_LETTER
    | GREEK_COMBINING
}

// Base Greek letters (both cases)
// Excludes U+037E (Greek question mark) and U+0387 (Greek ano teleia, though we use U+00B7)
GREEK_LETTER = {
    '\u{0370}'..'\u{037D}'
    | '\u{037F}'..'\u{0386}'
    | '\u{0388}'..'\u{03FF}'
    | '\u{1F00}'..'\u{1FFF}'
}

// Combining diacritical marks for Greek
GREEK_COMBINING = { '\u{0300}'..'\u{036F}' }

// =============================================================================
// Punctuation
// =============================================================================

// Full stop (τελεία) - ends a statement
period = { "." }

// Middle dot / ano teleia (U+00B7) - chains expressions within a statement
// This is the Greek semicolon/colon
chain = { "\u{00B7}" }

// Greek question mark (U+037E) - looks like semicolon but is the question mark
// Also accept ASCII ? for convenience
query = { "\u{037E}" | "?" }

// Comma - separates clauses (condition from body in control flow)
comma = { "," }

// =============================================================================
// Whitespace and comments
// =============================================================================

WHITESPACE = _{ " " | "\t" | "\r" | "\n" }

// Comments use // (like Rust) - reclaiming () for grouping/function calls
COMMENT = _{ "//" ~ (!NEWLINE ~ ANY)* ~ NEWLINE? }
NEWLINE = _{ "\r\n" | "\n" | "\r" }
