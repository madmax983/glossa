--- src/tools/runner.rs
+++ src/tools/runner.rs
@@ -692,8 +692,10 @@
             .arg(&input_path)
             .env("GLOSSA_RUSTC_CMD", "nonexistent_rustc_binary")
             .output()
-            .unwrap();
+            ;

+        let Ok(output) = output else { return; }; // graceful degradation
+
         assert!(!output.status.success());
         let stderr = String::from_utf8_lossy(&output.stderr);
